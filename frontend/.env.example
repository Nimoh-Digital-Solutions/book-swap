# =====================================================
# Environment Variables — copy to .env.local to use
# =====================================================
# This file documents all variables consumed by the app.
# Do NOT put real secrets here — this file is committed to source control.

# Base URL for API requests (used in APP_CONFIG.apiUrl).
# Dev default: points at the nimoh_base backend running locally.
# Production: leave empty when using the nginx reverse proxy — requests
# go to /api/ on the same origin and nginx forwards them to the backend.
# When present, must be a valid absolute URL (http:// or https://).
VITE_API_URL=http://localhost:8070

# WebSocket base URL for real-time features.
# OPTIONAL — when omitted, automatically derived from VITE_API_URL (http→ws, https→wss).
# Only set this explicitly if your WS server runs on a different host than the API.
# VITE_WS_URL=ws://localhost:8000

# Application display name (used in titles, metadata, PWA manifest)
# Optional — falls back to 'React Starter Kit'.
VITE_APP_TITLE=React Starter Kit

# Set to "true" to enable PWA service worker in development.
# Optional — has no effect when the PWA feature is not installed.
# VITE_PWA=true

# Set to "true" to enable HTTPS in development via mkcert.
# Needed for secure cookie testing, WebAuthn, and media APIs.
# On first run, mkcert will generate a locally-trusted CA certificate.
# VITE_HTTPS=true

# ── Sentry ────────────────────────────────────────────────────────────────────
# Sentry DSN for error tracking. Omit to disable Sentry (safe for local dev).
# VITE_SENTRY_DSN=https://9602c405de75e583087ba6cf9e20718c@o4510964813922304.ingest.de.sentry.io/4511263311921232

# Sentry environment tag ("production", "staging", "development").
# Defaults to "development" when omitted.
# VITE_SENTRY_ENVIRONMENT=development

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable a feature, "false" or omit to disable.
# Add project-specific flags with the naming convention VITE_FF_<FEATURE>.
#
# Example:
# VITE_FF_DARK_MODE=true

# ── SEO ───────────────────────────────────────────────────────────────────────
# Public site URL (used for canonical links, OG tags, sitemaps).
# Must NOT have a trailing slash.
VITE_SITE_URL=https://book-swaps.com

# ── Google Maps ────────────────────────────────────────────────────────────────
# Google Maps JavaScript API key (for map views)
VITE_GOOGLE_MAPS_API_KEY=

# ── Docker ────────────────────────────────────────────────────────────────────
# NPM auth token for publishing packages (used only in CI and Docker builds).
# Not required for installing — all packages are public on npm.
# NPM_TOKEN=npm_your_token_here
