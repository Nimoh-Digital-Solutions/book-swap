{
  "name": "bookswap",
  "version": "0.1.0",
  "description": "An app for booklovers to save on buying new books everytime they want read new books",
  "author": {
    "name": "Matthew Venter",
    "email": "matthewcpventer@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "yarn audit --level high",
    "check": "yarn audit --level high && yarn type-check && yarn lint && yarn stylelint && yarn test:run",
    "check:fix": "yarn lint:fix && yarn stylelint:fix && yarn format",
    "setup": "node scripts/setup.js",
    "setup:pwa": "node scripts/setup-pwa.js",
    "setup:testing": "node scripts/setup-testing.js",
    "setup:husky": "node scripts/setup-husky.js",
    "setup:docker": "node scripts/setup-docker.js",
    "setup:add-pwa": "node scripts/setup-add-pwa.js",
    "setup:add-testing": "node scripts/setup-add-testing.js",
    "setup:add-husky": "node scripts/setup-add-husky.js",
    "setup:add-docker": "node scripts/setup-add-docker.js",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@nimoh-digital-solutions/tast-hooks": "^1.0.0",
    "@nimoh-digital-solutions/tast-styles": "^1.1.0",
    "@nimoh-digital-solutions/tast-ui": "^1.1.0",
    "@nimoh-digital-solutions/tast-utils": "^1.1.0",
    "@react-leaflet/core": "^3.0.0",
    "@sentry/react": "^10.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "clsx": "^2.1.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.577.0",
    "motion": "^12.23.24",
    "open-props": "^1.7.23",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-router-dom": "^7.7.1",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^8.57.1",
    "@nimoh-digital-solutions/eslint-config": "^1.0.0",
    "@nimoh-digital-solutions/stylelint-config": "^1.0.0",
    "@nimoh-digital-solutions/tsconfig": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@stylistic/stylelint-plugin": "^3.1.3",
    "@tailwindcss/vite": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.5.0",
    "@types/jest-axe": "^3.5.9",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.0.14",
    "@types/postcss-pxtorem": "^6.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.10",
    "postcss": "^8.1.0",
    "postcss-jit-props": "^1.0.16",
    "postcss-pxtorem": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.75.0",
    "stylelint": "^16.21.1",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-scss": "^6.12.1",
    "tailwindcss": "^4",
    "typescript": "^5.3.3",
    "vite": "^7.0.5",
    "vite-plugin-checker": "^0.10.0",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-pwa": "^1.0.3",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
