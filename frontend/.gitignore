!.vscode/extensions.json
!.vscode/launch.json
.history/
*.swp
*.swo
*.swn
*.bak
*.orig

# JetBrains IDEs
.idea/
*.iml
*.iws

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
Sessionx.vim

# =============================================================================
# GitHub — only keep workflows
# =============================================================================
.github/*
!.github/workflows/

