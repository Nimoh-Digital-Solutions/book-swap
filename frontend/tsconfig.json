{
  "extends": "@nimoh-digital-solutions/tsconfig/base.json",
  "compilerOptions": {
    // Path Aliases (must match vite.config.ts)
    "baseUrl": "src",
    "paths": {
      "@assets": ["assets"],
      "@assets/*": ["assets/*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@configs": ["configs"],
      "@configs/*": ["configs/*"],
      "@constants": ["constants"],
      "@constants/*": ["constants/*"],
      "@contexts": ["contexts"],
      "@contexts/*": ["contexts/*"],
      "@data": ["data"],
      "@data/*": ["data/*"],
      "@hooks": ["hooks"],
      "@hooks/*": ["hooks/*"],
      "@layouts": ["layouts"],
      "@layouts/*": ["layouts/*"],
      "@pages": ["pages"],
      "@pages/*": ["pages/*"],
      "@routes": ["routes"],
      "@routes/*": ["routes/*"],
      "@styles": ["styles"],
      "@styles/*": ["styles/*"],
      "@types": ["types"],
      "@types/*": ["types/*"],
      "@utils": ["utils"],
      "@utils/*": ["utils/*"],
      "@services": ["services"],
      "@services/*": ["services/*"],
      "@features": ["features"],
      "@features/*": ["features/*"],
      "@test": ["test"],
      "@test/*": ["test/*"],
      "@shared": ["../../packages/shared/src"],
      "@shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "../packages/shared/src"],
  "exclude": ["node_modules", "dist"]
}
