# Expo SDK 54 pins react@19.1.0, while @testing-library/react-native@13.3.3
# pulls in react-test-renderer@19.2.5 which peer-depends on react@^19.2.5.
# This conflict cannot be resolved without breaking SDK 54 alignment, so we
# fall back to npm 6-style peer-dep resolution. Both `npm install` and `npm ci`
# read this file, keeping local and CI lockfile resolution consistent.
legacy-peer-deps=true
