# ─── BookSwap Mobile — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# All variables prefixed with EXPO_PUBLIC_ are embedded in the JS bundle at build time.

# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the BookSwap API (must include /api/v1 path)
# Must use HTTPS in staging/production (enforced at runtime)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Environment ──────────────────────────────────────────────────────────────
# One of: development | staging | production
EXPO_PUBLIC_ENV=development

# ─── Sentry (crash reporting) ─────────────────────────────────────────────────
# DSN from https://sentry.io → Settings → Projects → bookswap-mobile
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_MOBILE_SENTRY_DSN_HERE

# Prevents Sentry from uploading source maps during local dev builds
SENTRY_DISABLE_AUTO_UPLOAD=true

# ─── Google Sign-In ──────────────────────────────────────────────────────────
# OAuth 2.0 client IDs from Google Cloud Console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ─── Google Maps (Android) ───────────────────────────────────────────────────
# Maps SDK API key (required for Android map view in BrowseMapScreen)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── PostHog (product analytics) ─────────────────────────────────────────────
# API key from https://eu.posthog.com → Project Settings
EXPO_PUBLIC_POSTHOG_API_KEY=
# PostHog host (defaults to EU cloud)
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── EAS (Expo Application Services) ─────────────────────────────────────────
# Only needed for CI/CD — not required for local development
# EXPO_TOKEN=
