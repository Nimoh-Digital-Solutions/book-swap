{
  "name": "mobile",
  "version": "1.0.0",
  "main": "src/App.tsx",
  "scripts": {
    "start": "expo start --reset-cache --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "npx eslint src/"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": ["babel-jest", { "presets": ["babel-preset-expo"] }]
    },
    "testEnvironment": "node",
    "preset": "jest-expo/ios",
    "setupFiles": ["react-native/jest/setup", "<rootDir>/jest.setup.ts"],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|expo/virtual/.*|@sentry/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|react-native-mmkv|react-native-reanimated|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|react-native-toast-message|react-native-svg|@tanstack/.*|zustand|i18next|react-i18next|zod|lucide-react-native)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/../packages/shared/src/$1"
    },
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@sentry/react-native": "^8.7.0",
    "@tanstack/query-async-storage-persister": "^5.99.0",
    "@tanstack/query-sync-storage-persister": "^5.99.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.0",
    "axios": "^1.15.0",
    "expo": "~54.0.33",
    "expo-barcode-scanner": "^13.0.1",
    "expo-blur": "^55.0.14",
    "expo-camera": "^55.0.15",
    "expo-constants": "^55.0.14",
    "expo-device": "^55.0.15",
    "expo-image": "^55.0.8",
    "expo-linking": "^55.0.13",
    "expo-local-authentication": "^55.0.13",
    "expo-location": "^55.1.8",
    "expo-notifications": "^55.0.19",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "^55.0.18",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "^55.0.20",
    "i18next": "^26.0.5",
    "lucide-react-native": "^1.8.0",
    "react": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-maps": "^1.27.2",
    "react-native-maps-clustering": "^1.2.4",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-toast-message": "^2.3.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.1.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "typescript": "~5.9.2"
  },
  "private": true
}
