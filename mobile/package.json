{
  "name": "mobile",
  "version": "1.0.0",
  "main": "src/App.tsx",
  "scripts": {
    "start": "expo start --reset-cache --dev-client",
    "android": "expo run:android",
    "ios": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "prebuild": "expo prebuild",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 50",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prebuild:check": "bash scripts/check-env.sh",
    "build:android": "npm run prebuild:check && eas build --profile development:device --platform android",
    "build:ios": "npm run prebuild:check && eas build --profile development:device --platform ios",
    "build:ios:local": "npm run prebuild:check && eas build --profile development:device --platform ios --local",
    "build:android:local": "npm run prebuild:check && eas build --profile preview:store --platform android --local",
    "build:android:preview": "npm run prebuild:check && eas build --profile preview:store --platform android",
    "build:ios:preview": "npm run prebuild:check && eas build --profile preview --platform ios",
    "build:android:prod": "npm run prebuild:check && eas build --profile production --platform android",
    "build:ios:prod": "npm run prebuild:check && eas build --profile production --platform ios",
    "update:staging": "eas update --branch staging --message",
    "update:production": "eas update --branch production --message",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            [
              "babel-preset-expo",
              {
                "reanimated": false
              }
            ]
          ]
        }
      ]
    },
    "testEnvironment": "node",
    "preset": "jest-expo/ios",
    "setupFiles": [
      "react-native/jest/setup",
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|expo/virtual/.*|@sentry/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|react-native-mmkv|react-native-reanimated|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|react-native-toast-message|react-native-svg|@tanstack/.*|zustand|i18next|react-i18next|zod|lucide-react-native)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/../packages/shared/src/$1"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-async-storage-persister": "^5.99.0",
    "@tanstack/query-sync-storage-persister": "^5.99.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.0",
    "axios": "^1.15.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "^55.0.14",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "i18next": "^26.0.5",
    "lucide-react-native": "^1.8.0",
    "posthog-react-native": "^4.42.3",
    "react": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-maps-clustering": "^1.2.4",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "^0.8.1",
    "supercluster": "^8.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "@types/supercluster": "^7.1.3",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.0"
  },
  "private": true
}
