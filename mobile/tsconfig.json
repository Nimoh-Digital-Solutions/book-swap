{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src", "App.tsx", "index.ts", "../packages/shared/src"],
  "exclude": ["../packages/shared/src/**/__tests__/**", "src/**/__tests__/**", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
