# bookswap — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=IG)x_Jcqvsm^0&CCb=NK^oADJII186)0pSZ&=BhWn98XR$O&t_
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://gnimoh001:root@localhost:5432/bookswap


# ── Redis ─────────────────────────────────────────────────────────────────────
# Use the Docker service hostname 'redis' when running inside Docker.
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Set to false when running locally without a Celery worker (skips the worker check in /health/).
HEALTH_CHECK_CELERY=false


# ── Email ─────────────────────────────────────────────────────────────────────

SENDGRID_API_KEY=your-sendgrid-api-key-here

SUPPORT_EMAIL=support@bookswap.example
NOREPLY_EMAIL=noreply@bookswap.example

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed FE origins.
# :3070 = Vite dev server, :8150 = FE prod nginx — keep both for local development.
CORS_ALLOWED_ORIGINS=http://localhost:3070,http://localhost:8150,http://192.168.2.9:3070,
FRONTEND_URL=http://localhost:3070

# 'backend' allows the FE nginx container to reach this service by Docker service name.
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Production overrides (uncomment and set when deploying) ──────────────────
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# TRUSTED_PROXY_IPS=10.0.0.1          # your load-balancer / nginx IP
# APP_VERSION=1.0.0                   # surfaced at /api/v1/health/


SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=216671177456-bf0ejrae9t39rshpfu5oee2900dcol3s.apps.googleusercontent.com
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=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
# PSA always sends this exact URI to Google regardless of Host header (LAN IP, Docker internal, etc.)
# Must match an Authorized redirect URI in Google Cloud Console.
SOCIAL_AUTH_GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/complete/google-oauth2/
# GDAL / GEOS library paths (macOS Homebrew)
GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib
